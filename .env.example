# Studio → L2.5 ingest (opsiyonel ama önerilir)
L2_INGEST_TOKEN=change-me-long-secret

# --- Runtime ---
# local = yerel disk + subprocess | cloud = Drive + worker kuyruğu
L2_RUNTIME=cloud

# Repo kökü (gemini_direct / video_router). Vercel'de genelde boş bırak (otomatik).
# L2_CODE_ROOT=

# Yerel projeler (yalnız L2_RUNTIME=local)
L2_PROJECTS_ROOT=./projects

# Worker scratch (Drive'dan indirilen kopyalar)
L2_SCRATCH_ROOT=./.l2_scratch

# Google Drive — projelerin olduğu KÖK klasör ID (tek proje değil, üst klasör)
# Örnek: ice_cream_truck'ın parent'ı
L2_DRIVE_ROOT_ID=

# Service account JSON (tek satır) VEYA dosya yolu:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# API keys (worker makinesinde de gerekli; panel oturumda da yapıştırılabilir)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Worker
L2_WORKER_POLL_SEC=8
